{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["oh-my-opencode"],
  "permission": {
    "skill": {
      "*": "allow"
    }
  },
  "mcp": {
    "figma": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "oauth": {
        "clientId": "your_id",
        "clientSecret": "your_secret"
      }
    },
    "firecrawl": {
      "type": "remote",
      "url": "https://mcp.firecrawl.dev/your_key/v2/mcp",
      "enabled": true
    }
  }
}
